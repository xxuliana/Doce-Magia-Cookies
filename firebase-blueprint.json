{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Customer account data and loyalty points",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "points"]
    },
    "Order": {
      "title": "Order",
      "description": "Cookie order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "client": { "type": "string" },
        "phone": { "type": "string" },
        "delivery": { "type": "string", "enum": ["retirada", "delivery"] },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "obs": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "preparing", "shipping", "completed", "canceled"] },
        "date": { "type": "string", "format": "date-time" },
        "pointsRedeemed": { "type": "number" },
        "discountValue": { "type": "number" }
      },
      "required": ["client", "phone", "delivery", "items", "total", "status", "date"]
    },
    "Settings": {
      "title": "App Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "whatsappNumber": { "type": "string" },
        "deliveryFee": { "type": "number" },
        "messageTemplate1": { "type": "string" },
        "messageTemplate2": { "type": "string" },
        "messageTemplate3": { "type": "string" },
        "messageTemplate4": { "type": "string" },
        "loyaltyEnabled": { "type": "boolean" },
        "pointsPerReal": { "type": "number" },
        "realPerPoint": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and loyalty points"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/settings/main": {
      "schema": "Settings",
      "description": "Store settings"
    }
  }
}
