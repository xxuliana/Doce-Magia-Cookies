rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Bootstrap admin check
      return isSignedIn() && (
        request.auth.token.email == 'jumonteiro2901@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['name', 'email', 'phone', 'points', 'createdAt']) &&
                      incoming().points == 0 &&
                      !(incoming().keys().hasAny(['isAdmin']));
      allow update: if (isOwner(userId) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone'])) ||
                      isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      isVerified() &&
                      incoming().keys().hasAll(['client', 'phone', 'delivery', 'address', 'items', 'total', 'status', 'date', 'timestamp']) &&
                      incoming().status == 'pending' &&
                      incoming().timestamp == request.time &&
                      (incoming().userId == null || incoming().userId == request.auth.uid);
      
      allow update: if isAdmin() || (
                      isOwner(existing().userId) && 
                      existing().status == 'pending' &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['items', 'total', 'address', 'obs'])
                    );
      
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
