# .env.example
# Configurações de E-mail (Gmail)
# Use o seu e-mail do Gmail
EMAIL_USER=docemagiacookies@gmail.com

# Para o EMAIL_PASS, não use a sua senha normal do Gmail.
# Você deve gerar uma "Senha de App" (App Password) no Google:
# 1. Vá em Conta do Google > Segurança
# 2. Ative a Verificação em Duas Etapas
# 3. Procure por "Senhas de App"
# 4. Crie uma para "E-mail" e copie o código de 16 letras.
EMAIL_PASS=

# Stripe Configuration
# Pegue suas chaves em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Automação de WhatsApp (Opcional)
# Configure uma URL de API e uma chave para enviar mensagens automaticamente
# Exemplo: Twilio, Z-API, UltraMsg ou Evolution API
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
